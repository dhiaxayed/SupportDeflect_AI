# Application
ENVIRONMENT=local
DEBUG=true
DOCS_ENABLED=true
INIT_DATABASE_ON_STARTUP=true
SECRET_KEY=replace_with_a_long_random_secret_key
# Local Docker Postgres:
# DATABASE_URL=postgresql+psycopg://supportdeflect:supportdeflect@postgres:5432/supportdeflect
# Neon or hosted Postgres URLs are supported. Keep real credentials in backend/.env only.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8000","http://127.0.0.1:8000"]
TRUSTED_HOSTS=["localhost","127.0.0.1","*.localhost"]

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=mock

# Embeddings and vector store
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
ALLOW_FAKE_EMBEDDINGS_FALLBACK=true
VECTOR_PROVIDER=database
# Chroma remains available as an optional provider if chromadb is installed.
# CHROMA_PERSIST_DIRECTORY=./.chroma
# VECTOR_COLLECTION_NAME=supportdeflect_chunks

# RAG
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
MIN_CONFIDENCE_SCORE=0.35
INGESTION_MODE=queued
INGESTION_WORKER_POLL_SECONDS=2
INGESTION_JOB_MAX_ATTEMPTS=3

# Security limits
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_PROVIDER=database
WIDGET_RATE_LIMIT_PER_MINUTE=20
