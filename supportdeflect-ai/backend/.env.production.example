# Application
ENVIRONMENT=production
DEBUG=false
DOCS_ENABLED=false
INIT_DATABASE_ON_STARTUP=false
SECRET_KEY=replace_with_a_long_random_secret_key_at_least_32_chars
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
FRONTEND_URL=https://app.example.com
BACKEND_PUBLIC_URL=https://api.example.com
CORS_ORIGINS=["https://app.example.com"]
TRUSTED_HOSTS=["api.example.com"]

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# Embeddings and vector store
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
ALLOW_FAKE_EMBEDDINGS_FALLBACK=false
VECTOR_PROVIDER=database
# Neon/Postgres uses pgvector automatically with VECTOR_PROVIDER=database.

# RAG
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
MIN_CONFIDENCE_SCORE=0.35
INGESTION_MODE=queued
INGESTION_WORKER_POLL_SECONDS=2
INGESTION_JOB_MAX_ATTEMPTS=3

# Security limits
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_PROVIDER=database
ADMIN_RATE_LIMIT_PER_MINUTE=60
WIDGET_RATE_LIMIT_PER_MINUTE=20
